FROM golang:1.25-alpine AS build
WORKDIR /app
ARG SERVICE=saas-dx
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /server ./cmd/${SERVICE}

FROM alpine:3.20
RUN apk add --no-cache ca-certificates wget
COPY --from=build /server /server
ENV PORT=8080
EXPOSE 8080
CMD ["/server"]
