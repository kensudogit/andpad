# Copy to .env for docker compose:  cp .env.example .env

# Docker host ports (defaults avoid conflict with dev:monolith and other compose stacks)
# WEB_HOST_PORT=3001
# GATEWAY_HOST_PORT=18080
# MINIO_API_HOST_PORT=19000
# MINIO_CONSOLE_HOST_PORT=19001

# OpenAI (optional ť AI Board insights & consultation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local dev without Docker (memory store when DATABASE_URL is empty)
# DATABASE_URL=postgres://dental:dental@localhost:5432/dental_video?sslmode=disable
# JWT_SECRET=dev-only-change-in-production
# PORT=8080
# API_URL=http://localhost:8080
