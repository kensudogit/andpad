# Railway Variables for dental_video service (NOT the Postgres service)
#
# In Railway Dashboard:
#   joyful-acceptance ? production ? dental_video ? Variables

# REQUIRED — Reference from Postgres plugin (do not paste URL manually)
# Click "+ New Variable" ? Name: DATABASE_URL ? "Add Reference" ? Postgres ? DATABASE_URL
# DATABASE_URL is injected at deploy time (do not commit the real value)

# REQUIRED — Random string for login tokens (NOT an OpenAI/Anthropic API key)
JWT_SECRET=replace-with-long-random-string-like-a1b2c3d4e5f6...

# OPTIONAL — AI Board (separate from JWT_SECRET)
# OPENAI_API_KEY=sk-...

# Do NOT set on unified deploy:
# API_URL
